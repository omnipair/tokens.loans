# Copy this file to `.env.local` before running `npm run refresh-data`.
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/
JUPITER_PRICE_URL=https://api.jup.ag/price/v3
JUPITER_API_KEY=

# Vercel Marketplace-managed Upstash Redis injects these in preview/production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional cache overrides.
ASSETS_API_CACHE_TTL_SECONDS=3600
ASSETS_API_MAX_STALE_SECONDS=86400
ASSETS_API_REDIS_RECORD_TTL_SECONDS=93600
ASSETS_API_REDIS_LOCK_SECONDS=300
ASSETS_API_REDIS_KEY_PREFIX=tokens-loans:assets:v1
